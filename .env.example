# Public (browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=trivix-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_USE_EMULATORS=true
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# reCAPTCHA Enterprise site key for Firebase App Check (public)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Server
FIREBASE_PROJECT_ID=trivix-dev
USE_FIREBASE_EMULATORS=true
# Production only:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Admin notification emails (Resend). Both required for email delivery;
# if unset, notification sends are skipped (no error).
RESEND_API_KEY=
# Must be a verified Resend sender, e.g. "Trivix <notify@yourdomain.com>"
NOTIFICATIONS_FROM_EMAIL=
