rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isMemberOfTeam(teamId) {
      return isSignedIn() &&
        request.auth.uid in
          get(/databases/$(database)/documents/teams/$(teamId)).data.memberUids;
    }

    function isCaptainOfTeam(teamId) {
      return isSignedIn() &&
        request.auth.uid ==
          get(/databases/$(database)/documents/teams/$(teamId)).data.captainUid;
    }

    // users/{uid} — server-written via Admin SDK. Owner can read own doc.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // displayNames/{key} — uniqueness sentinel; entirely server-side.
    match /displayNames/{key} {
      allow read, write: if false;
    }

    // hostApplications/{uid} — server-written. Owner can read own status.
    match /hostApplications/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // teams/{teamId} — members can read; all writes server-only.
    match /teams/{teamId} {
      allow read: if isMemberOfTeam(teamId) || isCaptainOfTeam(teamId);
      allow write: if false;

      // joinRequests subcollection.
      // - Captain can read all pending requests on their team.
      // - Requester can read their own request.
      // - Any signed-in user can create their own request doc.
      // - Updates/deletes server-only (approval/denial cleans up via Admin SDK).
      match /joinRequests/{uid} {
        allow read: if isOwner(uid) || isCaptainOfTeam(teamId);
        allow create: if isOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.keys().hasOnly(["uid", "displayName", "requestedAt"]);
        allow update, delete: if false;
      }
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
