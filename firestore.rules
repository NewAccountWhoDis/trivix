rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isMemberOfTeam(teamId) {
      return isSignedIn() &&
        request.auth.uid in
          get(/databases/$(database)/documents/teams/$(teamId)).data.memberUids;
    }

    function isCaptainOfTeam(teamId) {
      return isSignedIn() &&
        request.auth.uid ==
          get(/databases/$(database)/documents/teams/$(teamId)).data.captainUid;
    }

    // users/{uid} — owner or admin can read; writes server-only.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    // displayNames/{key} — uniqueness sentinel; entirely server-side.
    match /displayNames/{key} {
      allow read, write: if false;
    }

    // hostApplications/{uid} — owner or admin can read; writes server-only.
    match /hostApplications/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    // venues/{venueId} — owner-host or admin can read; writes server-only.
    match /venues/{venueId} {
      allow read: if (isSignedIn() && resource.data.ownerUid == request.auth.uid)
        || isAdmin();
      allow write: if false;
    }

    // questionSets/{setId} — owner-host or admin can read; writes server-only.
    match /questionSets/{setId} {
      allow read: if (isSignedIn() && resource.data.ownerUid == request.auth.uid)
        || isAdmin();
      allow write: if false;
    }

    // gameSessions/{sessionId} — host, any joined player, or admin reads.
    match /gameSessions/{sessionId} {
      allow read: if (isSignedIn() && (
        resource.data.hostUid == request.auth.uid
        || request.auth.uid in resource.data.players
      )) || isAdmin();
      allow write: if false;
    }

    // gameSessionKeys/{sessionId} — host of the matching session or admin
    // reads. Holds the answer key separated from the player-safe session doc.
    match /gameSessionKeys/{sessionId} {
      allow read: if (isSignedIn()
        && exists(/databases/$(database)/documents/gameSessions/$(sessionId))
        && get(/databases/$(database)/documents/gameSessions/$(sessionId)).data.hostUid == request.auth.uid)
        || isAdmin();
      allow write: if false;
    }

    // adminSettings/{adminUid} — admin notification preferences. Any admin may
    // read (all admins are trusted); writes are server-only.
    match /adminSettings/{adminUid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // teams/{teamId} — members, captain, or admin can read; writes server-only.
    match /teams/{teamId} {
      allow read: if isMemberOfTeam(teamId) || isCaptainOfTeam(teamId) || isAdmin();
      allow write: if false;

      // joinRequests subcollection.
      match /joinRequests/{uid} {
        allow read: if isOwner(uid) || isCaptainOfTeam(teamId) || isAdmin();
        allow create: if isOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.keys().hasOnly(["uid", "displayName", "requestedAt"]);
        allow update, delete: if false;
      }
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
